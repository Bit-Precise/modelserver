  "info": {
    "description": "Typed management API used by the ModelServer dashboard. Proxy/LLM compatibility endpoints are intentionally excluded.",
    "title": "ModelServer Management API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/config": {
      "get": {
        "description": "Returns the public OAuth provider and login-page configuration.",
        "operationId": "getAuthConfig",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthConfig"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [],
        "summary": "Get login configuration",
        "tags": [
          "Authentication"
        ],
        "x-modelserver-authz": {
          "mode": "public",
          "scope": "none",
          "superadmin": "none"
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "operationId": "getCurrentUser",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponseUser"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Forbidden"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "AdminJWT": []
          }
        ],
        "summary": "Get current user",
        "tags": [
          "Current user"
        ],
        "x-modelserver-authz": {
          "mode": "authenticated",
          "scope": "none",
          "superadmin": "none"
        }
      }
    },
    "/api/v1/me/capabilities": {
      "get": {
        "description": "Returns stable system-scoped permission identifiers granted to the current user.",
        "operationId": "getCurrentUserCapabilities",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponseGlobalCapabilities"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Forbidden"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "AdminJWT": []
          }
        ],
        "summary": "Get current user's system capabilities",
        "tags": [
          "Current user",
          "Authorization"
        ],
        "x-modelserver-authz": {
          "mode": "authenticated",
          "scope": "none",
          "superadmin": "none"
        }
      }
    },
    "/api/v1/plans": {
      "get": {
        "operationId": "listPlans",
        "parameters": [
          {
            "description": "Page number, starting at one.",
            "explode": false,
            "in": "query",
            "name": "page",
            "schema": {
              "default": 1,
              "description": "Page number, starting at one.",
              "format": "int64",
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Number of plans returned per page.",
            "explode": false,
            "in": "query",
            "name": "per_page",
            "schema": {
              "default": 20,
              "description": "Number of plans returned per page.",
              "format": "int64",
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Plan field used for ordering.",
            "explode": false,
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "created_at",
              "description": "Plan field used for ordering.",
              "type": "string"
            }
          },
          {
            "description": "Sort direction.",
            "explode": false,
            "in": "query",
            "name": "order",
            "schema": {
              "default": "desc",
              "description": "Sort direction.",
              "enum": [
                "asc",
                "desc"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListResponsePlan"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Forbidden"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unprocessable Entity"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "AdminJWT": []
          }
        ],
        "summary": "List plans",
        "tags": [
          "Plans"
        ],
        "x-modelserver-authz": {
          "mode": "rbac",
          "scope": "system",
          "permission": "system.plans.read",
          "superadmin": "required"
        }
      }
    },
    "/api/v1/plans/{planID}": {
      "get": {
        "operationId": "getPlan",
        "parameters": [
          {
            "description": "Plan identifier.",
            "in": "path",
